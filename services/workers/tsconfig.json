{
  "extends": "@stillwater/typescript-config/base",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": true,
    "tsBuildInfoFile": ".turbo/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "trigger.config.ts"],
  "exclude": ["node_modules", "dist", ".turbo"]
}
