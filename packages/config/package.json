{
  "name": "@stillwater/config",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "@stillwater/source": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./env": {
      "@stillwater/source": "./src/env.ts",
      "default": "./src/env.ts"
    },
    "./jobs-client": {
      "@stillwater/source": "./src/jobs-client.ts",
      "default": "./src/jobs-client.ts"
    },
    "./site": {
      "@stillwater/source": "./src/site.ts",
      "default": "./src/site.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist .turbo",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "@trigger.dev/sdk": "^4.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@stillwater/typescript-config": "workspace:*",
    "@types/node": "^26.1.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.9"
  }
}
