{
  "extends": "@stillwater/typescript-config/library",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": ".turbo/tsconfig.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["es2022", "dom"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", ".turbo"]
}
