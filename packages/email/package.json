{
  "name": "@stillwater/email",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "@stillwater/source": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./templates/*": {
      "@stillwater/source": "./src/templates/*.tsx",
      "default": "./src/templates/*.tsx"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc --build",
    "dev": "email dev --dir src/templates --port 3333",
    "clean": "rm -rf dist .turbo",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "email preview"
  },
  "dependencies": {
    "@stillwater/config": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.6",
    "resend": "^6.17.2"
  },
  "devDependencies": {
    "@stillwater/typescript-config": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": "^19.2.7"
  }
}
